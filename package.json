{
  "name": "sikagit",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"npm run dev -w client\" \"npm run dev -w server\"",
    "build": "npm run build -w shared && npm run build -w server && npm run build -w client",
    "lint": "npm run lint -w client -w server",
    "docker:dev": "docker compose up --build",
    "docker:dev:detach": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:prod": "docker compose -f docker-compose.prod.yml up --build",
    "docker:prod:detach": "docker compose -f docker-compose.prod.yml up --build -d",
    "docker:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  }
}
